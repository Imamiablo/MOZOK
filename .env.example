DATABASE_URL=postgresql+psycopg://mozok:mozok@localhost:5432/mozok
LLM_PROVIDER=ollama_openai
OLLAMA_OPENAI_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_MODEL=qwen2.5-coder:32b
# Optional role-specific model routing. Leave blank to fall back to OLLAMA_MODEL.
LLM_DEFAULT_MODEL=
LLM_CHAT_MODEL=
LLM_SCENE_MODEL=
LLM_SEMANTIC_MODEL=
LLM_FAST_MODEL=
LLM_REASONING_MODEL=
LLM_SUMMARIZER_MODEL=
LLM_MAINTENANCE_MODEL=
# JSON or comma syntax, e.g. {"scene":"qwen2.5:32b"} or scene=qwen2.5:32b,fast=llama3.2:3b
LLM_MODEL_ALIASES=
# Game sandbox role overrides. These are optional; the in-game M menu can save the same idea to mozok_game/user_model_settings.json.
MOZOK_GAME_USE_API=0
MOZOK_GAME_MODEL_SETTINGS_PATH=
MOZOK_GAME_TICK_MODEL_ROLE=fast
MOZOK_GAME_CHAT_MODEL_ROLE=scene
MOZOK_GAME_SEMANTIC_MODEL_ROLE=semantic
MOZOK_GAME_SOCIAL_SCENE_MODEL_ROLE=scene
MOZOK_GAME_DECISION_VOICE_MODEL_ROLE=scene
# Game-side LLM performance budget. These keep the sandbox responsive by using
# local planning for low-salience ticks and reserving LLM calls for important moments.
MOZOK_GAME_MAX_LLM_TICKS_PER_TURN=1
MOZOK_GAME_LLM_TICK_COOLDOWN_TURNS=2
MOZOK_GAME_MAX_GROUP_CHAT_LLM_REPLIES=1
MOZOK_GAME_SOCIAL_SCENE_LLM_INTERVAL=4
MOZOK_GAME_ASYNC_LLM=1
MOZOK_GAME_ASYNC_WORKERS=1
MOZOK_GAME_ASYNC_PENDING_LIMIT=8
MOZOK_GAME_ASYNC_DECISION_TTL_TURNS=4
MOZOK_GAME_DECISION_VOICE_POLICY=important
MOZOK_GAME_COMPACT_PAYLOADS=1
MOZOK_GAME_RECENT_EVENT_LIMIT=4
MOZOK_GAME_CHAT_CONTEXT_CHARS=2600
MOZOK_GAME_SCENE_CONTEXT_CHARS=2400
MOZOK_GAME_KNOWN_OBJECT_LIMIT=10
EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
FAISS_INDEX_PATH=./data/faiss.index
FAISS_MAPPING_PATH=./data/faiss_mapping.json
